name: dockercompose3899482290045942242
services:
  osservice.apiservice:
    build:
      context: C:\Users\Usuario\Desktop\YVORY\ControleOrdemDeServico\Infra
      dockerfile: src/Apis/OsService.ApiService/Dockerfile
    container_name: osservice-api
    depends_on:
      sqlserver:
        condition: service_healthy
        required: true
    environment:
      ASPNETCORE_ENVIRONMENT: Development
      ASPNETCORE_HTTP_PORTS: "5021"
      ConnectionStrings__CreateTable: Server=sqlserver,1433;Database=master;User Id=sa;Password=SqlServer2024!Strong#;TrustServerCertificate=True;Encrypt=False;
      ConnectionStrings__DefaultConnection: Server=sqlserver,1433;Database=OsServiceDb;User Id=sa;Password=SqlServer2024!Strong#;TrustServerCertificate=True;Encrypt=False;MultipleActiveResultSets=true;
    networks:
      default: null
    ports:
      - mode: ingress
        target: 8080
        published: "8080"
        protocol: tcp
      - mode: ingress
        target: 5021
        published: "5021"
        protocol: tcp
  sqlserver:
    container_name: osservice-sqlserver
    environment:
      ACCEPT_EULA: "Y"
      SA_PASSWORD: SqlServer2024!Strong#
    healthcheck:
      test:
        - CMD-SHELL
        - /opt/mssql-tools18/bin/sqlcmd -S localhost -U sa -P "SqlServer2024!Strong#" -Q "SELECT 1" -C
      timeout: 5s
      interval: 10s
      retries: 10
    image: mcr.microsoft.com/mssql/server:2022-latest
    networks:
      default: null
    ports:
      - mode: ingress
        target: 1433
        published: "1433"
        protocol: tcp
    volumes:
      - type: volume
        source: sqlserver_data
        target: /var/opt/mssql
        volume: {}
networks:
  default:
    name: dockercompose3899482290045942242_default
volumes:
  sqlserver_data:
    name: dockercompose3899482290045942242_sqlserver_data